{
  "buildCommand": "npm run build && cp landing.html dist/landing.html",
  "outputDirectory": "dist",
  "framework": null,
  "routes": [
    {
      "src": "/landing.html",
      "dest": "/landing.html"
    },
    {
      "src": "/index.html",
      "dest": "/index.html"
    },
    {
      "src": "^/$",
      "dest": "/landing.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}